<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/splash_bg">
    <ImageView android:id="@+id/iv_splash_logo" android:layout_width="110dp" android:layout_height="110dp"
        android:src="@drawable/ic_leaf_logo" android:contentDescription="@string/app_name"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/tv_app_name" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"/>
    <TextView android:id="@+id/tv_app_name" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/app_name" android:textSize="40sp" android:textStyle="bold"
        android:textColor="@color/white" android:letterSpacing="0.08"
        app:layout_constraintBottom_toTopOf="@id/tv_tagline" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toBottomOf="@id/iv_splash_logo"/>
    <TextView android:id="@+id/tv_tagline" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/tagline" android:textSize="15sp" android:textColor="#BDFFFFFF"
        android:layout_marginBottom="130dp"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toBottomOf="@id/tv_app_name"/>
</androidx.constraintlayout.widget.ConstraintLayout>
