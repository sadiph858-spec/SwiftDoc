<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="?attr/colorSurface">
    <com.google.android.material.appbar.AppBarLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar_img2pdf"
            android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
            android:background="@color/primary" app:titleTextColor="@color/white"/>
    </com.google.android.material.appbar.AppBarLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">
            <!-- Selected images preview -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Selected Images" android:textSize="16sp" android:textStyle="bold"
                android:textColor="@color/primary"/>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_images"
                android:layout_width="match_parent" android:layout_height="120dp"
                android:layout_marginTop="8dp" android:layout_marginBottom="12dp"/>
            <Button android:id="@+id/btn_add_images" android:layout_width="match_parent" android:layout_height="44dp"
                android:text="+ Add More Images" android:backgroundTint="@color/green_light"
                android:textColor="@color/white" android:layout_marginBottom="16dp"/>
            <!-- Filter preview -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Filter Preview" android:textSize="16sp" android:textStyle="bold"
                android:textColor="@color/primary"/>
            <ImageView android:id="@+id/iv_filter_preview" android:layout_width="match_parent"
                android:layout_height="200dp" android:layout_marginTop="8dp"
                android:scaleType="centerCrop" android:background="#FFE8F5E9"/>
            <!-- Filter options -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Choose Filter" android:textSize="16sp" android:textStyle="bold"
                android:textColor="@color/primary" android:layout_marginTop="16dp"/>
            <RadioGroup android:id="@+id/rg_filter" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="8dp">
                <RadioButton android:id="@+id/rb_original" android:layout_width="match_parent"
                    android:layout_height="48dp" android:text="🖼 Original (No Changes)"
                    android:checked="true" android:paddingStart="8dp"/>
                <RadioButton android:id="@+id/rb_document" android:layout_width="match_parent"
                    android:layout_height="48dp" android:text="📄 Document (Auto-Enhance Contrast)"
                    android:paddingStart="8dp"/>
                <RadioButton android:id="@+id/rb_grayscale" android:layout_width="match_parent"
                    android:layout_height="48dp" android:text="🩶 Grayscale (Professional Gray)"
                    android:paddingStart="8dp"/>
                <RadioButton android:id="@+id/rb_bw" android:layout_width="match_parent"
                    android:layout_height="48dp" android:text="⬛ High-Contrast B&amp;W (Scanner Look)"
                    android:paddingStart="8dp"/>
                <RadioButton android:id="@+id/rb_bright" android:layout_width="match_parent"
                    android:layout_height="48dp" android:text="☀️ Brightness Boost (Low-Light Fix)"
                    android:paddingStart="8dp"/>
            </RadioGroup>
            <ProgressBar android:id="@+id/pb_convert" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:visibility="gone" android:layout_marginTop="8dp"/>
            <FrameLayout android:id="@+id/ad_container" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:visibility="gone" android:layout_marginTop="8dp"/>
        </LinearLayout>
    </ScrollView>
    <Button android:id="@+id/btn_convert" android:layout_width="match_parent" android:layout_height="56dp"
        android:text="🔄 Convert to PDF &amp; Save" android:textSize="16sp" android:textStyle="bold"
        android:backgroundTint="@color/primary" android:textColor="@color/white"
        android:layout_marginLeft="16dp" android:layout_marginRight="16dp" android:layout_marginBottom="16dp"/>
</LinearLayout>
