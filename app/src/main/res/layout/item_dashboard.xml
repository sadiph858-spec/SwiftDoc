<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:padding="6dp" android:orientation="vertical">
    <androidx.cardview.widget.CardView android:id="@+id/card_dash"
        android:layout_width="match_parent" android:layout_height="100dp"
        app:cardCornerRadius="16dp" app:cardElevation="4dp"
        android:foreground="?attr/selectableItemBackground">
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="vertical" android:gravity="center" android:padding="8dp">
            <ImageView android:id="@+id/iv_dash_icon" android:layout_width="32dp" android:layout_height="32dp"
                android:contentDescription="@null" app:tint="@color/white"/>
            <TextView android:id="@+id/tv_dash_title" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold"
                android:gravity="center" android:layout_marginTop="6dp" android:maxLines="1"/>
            <TextView android:id="@+id/tv_dash_sub" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#BDFFFFFF" android:textSize="10sp" android:gravity="center"
                android:layout_marginTop="2dp" android:maxLines="1"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
