<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A1A">

    <!-- PDF page image — pinch zoom handled by PhotoView or matrix -->
    <ImageView
        android:id="@+id/iv_pdf_page"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:background="#FF1A1A1A"
        android:hardwareAccelerated="true"/>

    <!-- Per-page loading spinner (shown only while decoding) -->
    <ProgressBar
        android:id="@+id/spinner_page"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FF4CAF50"
        android:visibility="visible"/>

</FrameLayout>
